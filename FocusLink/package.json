{
  "name": "focuslink",
  "version": "0.11.5",
  "description": "FocusLink - 全局快捷键驱动的专注时间记录器 + 滴答清单任务关联器",
  "author": "FocusLink",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "vite",
    "gen-version": "node scripts/build/gen-version.js",
    "build": "npm run gen-version && tsc --noEmit && vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "manual-test": "vitest run scripts/regression/manual-timer-regression.ts",
    "build:selftest": "node scripts/build/build-selftest.mjs",
    "regression:electron": "npm run build:selftest && electron dist-selftest/selftest.cjs && electron dist-selftest/task-test.cjs && electron dist-selftest/crash-recovery.cjs start && electron dist-selftest/crash-recovery.cjs recover-running && electron dist-selftest/crash-recovery.cjs recover-paused",
    "build:icons": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build/make-minimal-icons.ps1",
    "smoke:ui": "node scripts/smoke/ui-state-smoke.cjs",
    "smoke:mini": "node scripts/smoke/mini-ui-smoke.cjs",
    "smoke:dida": "node scripts/smoke/dida-real-smoke.cjs",
    "smoke:dida:state": "npm run build:selftest && node dist-selftest/dida-task-state-smoke.cjs",
    "smoke:dida:ui": "node scripts/smoke/dida-task-ui-smoke.cjs",
    "smoke:tomatodo:real": "npm run build:selftest && node dist-selftest/tomatodo-cloud-real-smoke.cjs",
    "smoke:tomatodo:bridge": "npm run build:selftest && node dist-selftest/tomatodo-cloud-real-smoke.cjs --probe-only",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\" \"shared/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.{ts,js,mjs,cjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\" \"shared/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.{ts,js,mjs,cjs}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"shared/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"shared/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "better-sqlite3": "^11.3.0",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.412.0",
    "ws": "^8.21.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.0.3"
  }
}
